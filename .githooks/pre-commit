REPO_ROOT=$(git rev-parse --show-toplevel)

# Only run if packet_analysis/ files have changed
CHANGED=$(git diff --cached --name-only --diff-filter=ACM | grep -c "^packet_analysis/.*\.yaml$" 2>/dev/null)
if [ "$CHANGED" -eq 0 ]; then
    exit 0
fi

# Check if tshark is available
if ! command -v tshark &>/dev/null; then
    echo "⚠️  tshark not found, skipping field validation"
    echo "   Install with: sudo apt install tshark"
    exit 0
fi

echo "🔍 Validating tshark fields in packet_analysis..."

python3 "$REPO_ROOT/.github/scripts/validate_tshark_fields.py"
exit $?
